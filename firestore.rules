rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    function isValidSeverity(val) {
      return val is int && val >= 1 && val <= 5;
    }

    // ── users/{userId} ────────────────────────────────────────
    // - Any authenticated user can read any profile (needed for
    //   Guardian discovery and incident attribution)
    // - Only the owner can write their own document

    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // accounts are never deleted via client
    }

    // ── incidents/{incidentId} ────────────────────────────────
    // - Any authenticated user can read active incidents
    // - Any authenticated user can create an incident
    // - Only the author can update their own incident
    // - Validations (confirm/dispute) are allowed by any auth user
    //   as long as they are not changing restricted fields

    match /incidents/{incidentId} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && request.resource.data.reportedBy == request.auth.uid
        && isValidSeverity(request.resource.data.severity)
        && isValidString(request.resource.data.description, 500);
      allow update: if isAuth() && (
        // Author can update any field
        resource.data.reportedBy == request.auth.uid
        ||
        // Others can only touch validations
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['validations'])
      );
      allow delete: if isAuth()
        && resource.data.reportedBy == request.auth.uid;
    }

    // ── routes/{routeId} ─────────────────────────────────────
    // - Only the owner can read/write their routes

    match /routes/{routeId} {
      allow read:   if isOwner(resource.data.userId);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── guardian_sessions/{sessionId} ────────────────────────
    // - Any authenticated user can read sessions (to find nearby guardians)
    // - Only the guardian (owner) can create/update/delete their session

    match /guardian_sessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && request.resource.data.guardianId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.guardianId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.guardianId == request.auth.uid;
    }

    // ── sos_alerts/{alertId} ─────────────────────────────────
    // - Public read access for tracking page (trusted contacts need to see location)
    // - Only the alert owner can create/update SOS alerts
    // - Guardians assigned to respond can also update

    match /sos_alerts/{alertId} {
      allow read: if true; // Public read for tracking links sent via SMS
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || request.auth.uid in resource.data.respondingGuardians
      );
      allow delete: if false; // SOS alerts are never deleted, only resolved
    }

    // ── notifications/{notificationId} ───────────────────────
    // - Only the recipient can read their notifications
    // - Only read + mark-as-read updates allowed from client

    match /notifications/{notificationId} {
      allow read:   if isOwner(resource.data.userId);
      allow create: if false; // created server-side only (Cloud Functions or trusted client)
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['read', 'readAt']);
      allow delete: if false;
    }

    // ── achievements/{achievementId} ─────────────────────────
    // - Public catalogue: any authenticated user can read
    // - Only writable via Admin SDK / Cloud Functions

    match /achievements/{achievementId} {
      allow read:   if isAuth();
      allow write:  if false;
    }

    // ── user_achievements/{userId}/achievements/{id} ─────────
    // - Only the owner can read their unlocked achievements
    // - Unlocking is done server-side only

    match /user_achievements/{userId}/achievements/{achievementId} {
      allow read:   if isOwner(userId);
      allow write:  if false;
    }

  }
}